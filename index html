<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="theme-color" content="#EDEAE2">
<title>Carnet de charge — Full Body</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#EDEAE2; --card:#FAF8F3; --ink:#27241F; --muted:#8C857A;
    --line:#DBD5C9; --olive:#6B7B5E; --amber:#B27A24; --red:#B23B2E;
    --display:'Space Grotesk',system-ui,sans-serif;
    --body:'Inter',system-ui,sans-serif;
    --mono:'Space Mono',ui-monospace,monospace;
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;margin:0;padding:0}
  html,body{background:var(--paper);color:var(--ink);font-family:var(--body)}
  body{min-height:100vh}
  .wrap{max-width:560px;margin:0 auto;padding:0 16px 130px}
  input[type=number]::-webkit-inner-spin-button,input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none;margin:0}
  input[type=number]{-moz-appearance:textfield}
  input:focus,textarea:focus{outline:none;border-color:var(--ink)!important}
  button{font-family:inherit;cursor:pointer}
  @media(prefers-reduced-motion:reduce){*{transition:none!important}}

  header{padding:28px 0 16px}
  .eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--olive)}
  .title-row{display:flex;align-items:baseline;justify-content:space-between;margin-top:6px}
  h1{font-family:var(--display);font-weight:700;font-size:30px;letter-spacing:-.02em}
  .info-btn{display:grid;place-items:center;width:36px;height:36px;border-radius:10px;border:none;background:transparent;color:var(--muted)}
  .info-btn.on{color:var(--olive)}
  .help{margin-top:12px;padding:14px 16px;background:var(--card);border:1px solid var(--line);border-radius:12px;font-size:13.5px;line-height:1.55;display:none}
  .help.show{display:block}
  .help strong{font-family:var(--display)}
  .help .amber{color:var(--amber);font-weight:600}

  .week{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
  .nav-btn{display:grid;place-items:center;width:44px;height:44px;border-radius:10px;border:1px solid var(--line);background:var(--card);color:var(--ink)}
  .nav-btn:disabled{color:var(--line);cursor:default}
  .week-c{text-align:center}
  .week-l{font-family:var(--mono);font-size:10px;letter-spacing:.2em;color:var(--muted);text-transform:uppercase}
  .week-n{font-family:var(--display);font-size:22px;font-weight:600;line-height:1}
  .week-n span{color:var(--muted);font-size:14px;font-weight:400}

  .tabs{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:18px}
  .tab{position:relative;padding:12px 8px;border-radius:12px;border:1.5px solid var(--line);background:var(--card);color:var(--ink);font-family:var(--display);font-weight:600;transition:all .15s}
  .tab.active{border-color:var(--ink);background:var(--ink);color:var(--paper)}
  .tab-l{font-family:var(--mono);font-size:9px;letter-spacing:.18em;opacity:.55;text-transform:uppercase}
  .tab.active .tab-l{opacity:.7}
  .tab-k{font-size:22px;line-height:1.1}
  .tab-done{position:absolute;top:7px;right:7px;width:16px;height:16px;border-radius:99px;background:var(--olive);display:none;place-items:center}
  .tab-done.show{display:grid}
  .tab-done svg{width:11px;height:11px}

  .sbar{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:4px}
  .sbar-t{font-family:var(--display);font-weight:700;font-size:18px}
  .sbar-s{color:var(--muted);margin-left:8px;font-size:13px}
  .sbar-p{font-family:var(--mono);font-size:12px;color:var(--muted)}
  .sbar-p.full{color:var(--olive)}
  .pbar{height:4px;background:var(--line);border-radius:99px;overflow:hidden;margin-bottom:16px}
  .pbar-f{height:100%;width:0;background:var(--ink);transition:width .3s}
  .pbar-f.full{background:var(--olive)}

  .ex-list{display:flex;flex-direction:column;gap:12px}
  .card{background:var(--card);border-radius:14px;padding:14px 14px 12px;border:1px solid var(--line);transition:all .2s}
  .card.ready{border-color:var(--amber);box-shadow:0 0 0 1px var(--amber)}
  .ex-head{display:flex;justify-content:space-between;align-items:flex-start;gap:10px}
  .ex-name{font-family:var(--display);font-weight:600;font-size:15.5px;line-height:1.25}
  .ex-target{font-family:var(--mono);font-size:12px;color:var(--muted);margin-top:2px}
  .chip{flex-shrink:0;display:none;align-items:center;gap:5px;background:var(--amber);color:#fff;padding:5px 9px;border-radius:99px;font-family:var(--mono);font-size:11px;font-weight:700;white-space:nowrap}
  .chip.show{display:flex}
  .chip svg{width:13px;height:13px}
  .sets{margin-top:11px;display:flex;flex-direction:column;gap:7px}
  .set{display:flex;align-items:center;gap:8px}
  .set-n{font-family:var(--mono);font-size:11px;color:var(--muted);width:14px;flex-shrink:0}
  .x{color:var(--line);font-size:14px}
  .field{position:relative;flex:1}
  .field input{width:100%;padding:9px 38px 9px 11px;border-radius:9px;border:1px solid var(--line);background:var(--paper);color:var(--ink);font-family:var(--body);font-size:15px;font-variant-numeric:tabular-nums}
  .field input.hit{border-color:var(--olive);background:rgba(107,123,94,.08)}
  .field .unit{position:absolute;right:10px;top:50%;transform:translateY(-50%);font-family:var(--mono);font-size:10px;color:var(--muted);pointer-events:none}

  .notes-l{font-family:var(--mono);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}
  textarea{width:100%;margin-top:6px;padding:10px 12px;border-radius:10px;border:1px solid var(--line);background:var(--card);color:var(--ink);font-family:var(--body);font-size:14px;resize:vertical}
  .actions{display:flex;gap:10px;margin-top:16px;align-items:center}
  .done-btn{flex:1;padding:13px;border-radius:12px;font-family:var(--display);font-weight:600;font-size:15px;border:1.5px solid var(--ink);background:transparent;color:var(--ink);display:flex;align-items:center;justify-content:center;gap:8px}
  .done-btn.done{border-color:var(--olive);background:var(--olive);color:#fff}
  .done-btn svg{width:18px;height:18px}
  .reset-btn{display:grid;place-items:center;width:48px;height:48px;border-radius:10px;border:1px solid var(--line);background:transparent;color:var(--muted)}

  .timer{position:fixed;bottom:18px;left:50%;transform:translateX(-50%);z-index:40;width:calc(100% - 32px);max-width:528px}
  .timer-in{background:var(--ink);color:var(--paper);border-radius:16px;padding:10px 12px;box-shadow:0 8px 30px rgba(0,0,0,.28);display:flex;align-items:center;gap:10px}
  .timer-ico{flex-shrink:0;color:var(--paper)}
  .timer-ico.run{color:var(--amber)}
  .timer-d{font-family:var(--mono);font-size:20px;font-weight:700;font-variant-numeric:tabular-nums;min-width:58px}
  .timer-d.warn{color:var(--amber)}
  .timer-btns{display:flex;gap:6px;margin-left:auto}
  .t-btn{padding:7px 12px;border-radius:10px;border:none;background:rgba(255,255,255,.14);color:var(--paper);font-family:var(--mono);font-size:13px;font-weight:600}
  .t-stop{display:none;place-items:center;width:38px;height:38px;background:rgba(255,255,255,.12);color:var(--paper);border-radius:10px;border:none}
  .t-stop.show{display:grid}
  .t-stop svg{width:16px;height:16px}

  .modal{position:fixed;inset:0;background:rgba(20,18,15,.45);z-index:60;display:none;place-items:center;padding:20px}
  .modal.show{display:grid}
  .modal-c{background:var(--paper);border-radius:16px;padding:20px;max-width:360px;width:100%;border:1px solid var(--line)}
  .modal-t{font-family:var(--display);font-weight:700;font-size:18px;margin-bottom:6px}
  .modal-p{color:var(--muted);font-size:14px;line-height:1.5}
  .modal-btns{display:flex;gap:10px;margin-top:16px}
  .modal-btns button{flex:1;padding:12px;border-radius:10px;font-family:var(--display);font-weight:600}
  .m-cancel{border:1px solid var(--line);background:transparent;color:var(--ink)}
  .m-ok{border:none;background:var(--red);color:#fff}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="eyebrow">Full Body · 3×/sem · Hypertrophie</div>
    <div class="title-row">
      <h1>Carnet de charge</h1>
      <button class="info-btn" id="infoBtn" aria-label="Aide">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      </button>
    </div>
    <div class="help" id="help">
      <strong>Double progression.</strong> Pars en bas de la fourchette. Chaque semaine, ajoute 1–2 reps.
      Quand <em>toutes</em> tes séries atteignent le haut de la fourchette, la ligne passe en
      <span class="amber">ambre</span> : monte la charge de l'incrément indiqué et redescends en bas de la fourchette.
      C'est la surcharge progressive, le moteur de l'hypertrophie.
    </div>
  </header>

  <div class="week">
    <button class="nav-btn" id="prevWeek" aria-label="Semaine précédente">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <div class="week-c">
      <div class="week-l">Semaine</div>
      <div class="week-n"><span id="weekNum">1</span><span> / 12</span></div>
    </div>
    <button class="nav-btn" id="nextWeek" aria-label="Semaine suivante">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
  </div>

  <div class="tabs" id="tabs"></div>

  <div class="sbar">
    <div><span class="sbar-t" id="sLabel"></span><span class="sbar-s" id="sSub"></span></div>
    <span class="sbar-p" id="sPct">0%</span>
  </div>
  <div class="pbar"><div class="pbar-f" id="pbarFill"></div></div>

  <div class="ex-list" id="exList"></div>

  <div style="margin-top:18px">
    <label class="notes-l">Notes de séance</label>
    <textarea id="notes" rows="2" placeholder="Sensations, douleurs, ajustements…"></textarea>
  </div>

  <div class="actions">
    <button class="done-btn" id="doneBtn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      <span id="doneTxt">Marquer terminée</span>
    </button>
    <button class="reset-btn" id="resetBtn" aria-label="Réinitialiser">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
    </button>
  </div>
</div>

<div class="timer">
  <div class="timer-in">
    <svg class="timer-ico" id="timerIco" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="10" x2="14" y1="2" y2="2"/><line x1="12" x2="15" y1="14" y2="11"/><circle cx="12" cy="14" r="8"/></svg>
    <div class="timer-d" id="timerD">Repos</div>
    <div class="timer-btns">
      <button class="t-btn" data-sec="90">1:30</button>
      <button class="t-btn" data-sec="120">2:00</button>
      <button class="t-stop" id="timerStop" aria-label="Arrêter">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
</div>

<div class="modal" id="modal">
  <div class="modal-c">
    <div class="modal-t">Tout effacer ?</div>
    <p class="modal-p">Toutes les charges et reps des 12 semaines seront remises à zéro. Action irréversible.</p>
    <div class="modal-btns">
      <button class="m-cancel" id="mCancel">Annuler</button>
      <button class="m-ok" id="mOk">Effacer</button>
    </div>
  </div>
</div>

<script>
const PROGRAM = {
  A:{label:"Séance A",sub:"Squat dominant",exercises:[
    {id:"a1",name:"Squat barre",sets:4,low:8,high:10,inc:5,type:"weight"},
    {id:"a2",name:"Développé couché haltères",sets:4,low:8,high:10,inc:2.5,type:"weight"},
    {id:"a3",name:"Tirage horizontal",sets:4,low:10,high:12,inc:2.5,type:"weight"},
    {id:"a4",name:"Élévations latérales",sets:3,low:12,high:15,inc:2.5,type:"weight"},
    {id:"a5",name:"Curl biceps haltères",sets:3,low:10,high:12,inc:2.5,type:"weight"},
    {id:"a6",name:"Gainage planche",sets:3,low:45,high:45,inc:10,type:"time"},
  ]},
  B:{label:"Séance B",sub:"Charnière de hanche",exercises:[
    {id:"b1",name:"Soulevé de terre roumain",sets:4,low:8,high:10,inc:5,type:"weight"},
    {id:"b2",name:"Développé militaire",sets:4,low:8,high:10,inc:2.5,type:"weight"},
    {id:"b3",name:"Tractions assistées / tirage vertical",sets:4,low:8,high:10,inc:2.5,type:"weight"},
    {id:"b4",name:"Presse à cuisses",sets:3,low:10,high:12,inc:5,type:"weight"},
    {id:"b5",name:"Extensions triceps poulie",sets:3,low:10,high:12,inc:2.5,type:"weight"},
    {id:"b6",name:"Face pull",sets:3,low:15,high:20,inc:2.5,type:"weight",hint:"Charge légère, qualité"},
  ]},
  C:{label:"Séance C",sub:"Unilatéral & incliné",exercises:[
    {id:"c1",name:"Fentes marchées haltères",sets:3,low:10,high:10,inc:2.5,type:"weight",suffix:"/jambe"},
    {id:"c2",name:"Développé incliné haltères",sets:4,low:8,high:10,inc:2.5,type:"weight"},
    {id:"c3",name:"Rowing barre (pronation)",sets:4,low:8,high:10,inc:2.5,type:"weight"},
    {id:"c4",name:"Leg curl allongé",sets:3,low:12,high:12,inc:2.5,type:"weight"},
    {id:"c5",name:"Élévations latérales",sets:3,low:12,high:15,inc:2.5,type:"weight"},
    {id:"c6",name:"Curl marteau",sets:3,low:10,high:12,inc:2.5,type:"weight"},
  ]},
};
const ORDER=["A","B","C"], WEEKS=12, KEY="fullbody_tracker_v1";

function emptyData(){
  const d={};
  for(let w=1;w<=WEEKS;w++){d[w]={};
    for(const k of ORDER){
      d[w][k]={sets:PROGRAM[k].exercises.map(e=>Array.from({length:e.sets},()=>({w:"",r:""}))),notes:"",done:false};
    }}
  return d;
}
let state, week=1, session="A";
try{
  const raw=localStorage.getItem(KEY);
  if(raw){const p=JSON.parse(raw); state=p.data||emptyData(); week=p.week||1; session=p.session||"A";}
  else state=emptyData();
}catch(e){state=emptyData();}

let saveT;
function save(){
  clearTimeout(saveT);
  saveT=setTimeout(()=>{
    try{localStorage.setItem(KEY,JSON.stringify({data:state,week,session}));}catch(e){}
  },300);
}

function readyToProgress(ex,sets){
  return sets.every(s=>s.r!==""&&Number(s.r)>=ex.high&&(ex.type==="time"||s.w!==""));
}
function progress(exList,sets){
  let t=0,f=0;
  exList.forEach((ex,i)=>sets[i].forEach(s=>{t++; if(ex.type==="time"?s.r!=="":(s.r!==""&&s.w!=="")) f++;}));
  return t?Math.round(f/t*100):0;
}
function targetStr(ex){
  if(ex.type==="time") return ex.sets+" × "+ex.low+" s";
  const r=ex.low===ex.high?ex.low:ex.low+"–"+ex.high;
  return ex.sets+" × "+r+(ex.suffix||"");
}
const ICON_TREND='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 7h6v6"/><path d="m22 7-8.5 8.5-5-5L2 17"/></svg>';
const ICON_CHECK='<svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';

const tabsEl=document.getElementById("tabs");
function renderTabs(){
  tabsEl.innerHTML="";
  ORDER.forEach(k=>{
    const b=document.createElement("button");
    b.className="tab"+(k===session?" active":"");
    b.innerHTML='<div class="tab-l">Séance</div><div class="tab-k">'+k+'</div><div class="tab-done'+(state[week][k].done?" show":"")+'">'+ICON_CHECK+'</div>';
    b.onclick=()=>{session=k; save(); renderAll();};
    tabsEl.appendChild(b);
  });
}

const exListEl=document.getElementById("exList");
function renderSession(){
  const prog=PROGRAM[session], cur=state[week][session];
  document.getElementById("sLabel").textContent=prog.label;
  document.getElementById("sSub").textContent=prog.sub;
  document.getElementById("notes").value=cur.notes;
  updateDone();

  exListEl.innerHTML="";
  prog.exercises.forEach((ex,i)=>{
    const card=document.createElement("div");
    card.className="card"; card.id="card-"+i;
    const ready=readyToProgress(ex,cur.sets[i]);
    if(ready) card.classList.add("ready");

    let html='<div class="ex-head"><div style="min-width:0">'
      +'<div class="ex-name">'+ex.name+'</div>'
      +'<div class="ex-target">'+targetStr(ex)+(ex.hint?' · '+ex.hint:'')+'</div></div>'
      +'<div class="chip'+(ready?" show":"")+'" id="chip-'+i+'">'+ICON_TREND+' +'+ex.inc+(ex.type==="time"?"s":"kg")+'</div></div>'
      +'<div class="sets">';
    cur.sets[i].forEach((s,si)=>{
      const hit=s.r!==""&&Number(s.r)>=ex.high;
      html+='<div class="set"><div class="set-n">'+(si+1)+'</div>';
      if(ex.type==="weight"){
        html+=field(i,si,"w",s.w,"kg",false)+'<span class="x">×</span>';
      }
      html+=field(i,si,"r",s.r,ex.type==="time"?"sec":"reps",hit)+'</div>';
    });
    html+='</div>';
    card.innerHTML=html;
    exListEl.appendChild(card);
  });

  exListEl.querySelectorAll("input").forEach(inp=>{
    inp.addEventListener("input",onInput);
  });
  updateProgress();
}
function field(i,si,f,val,unit,hit){
  return '<div class="field"><input type="number" inputmode="decimal" data-ex="'+i+'" data-set="'+si+'" data-f="'+f+'" value="'+val+'" placeholder="—" class="'+(hit?"hit":"")+'"><span class="unit">'+unit+'</span></div>';
}

function onInput(e){
  const inp=e.target, i=+inp.dataset.ex, si=+inp.dataset.set, f=inp.dataset.f;
  let v=inp.value;
  if(v!==""&&Number(v)<0){v="0"; inp.value="0";}
  state[week][session].sets[i][si][f]=v;
  const ex=PROGRAM[session].exercises[i];
  if(f==="r"){
    const hit=v!==""&&Number(v)>=ex.high;
    inp.classList.toggle("hit",hit);
  }
  const ready=readyToProgress(ex,state[week][session].sets[i]);
  document.getElementById("card-"+i).classList.toggle("ready",ready);
  document.getElementById("chip-"+i).classList.toggle("show",ready);
  updateProgress();
  save();
}

function updateProgress(){
  const prog=PROGRAM[session], cur=state[week][session];
  const pct=progress(prog.exercises,cur.sets);
  const p=document.getElementById("sPct"), f=document.getElementById("pbarFill");
  p.textContent=pct+"%"; p.classList.toggle("full",pct===100);
  f.style.width=pct+"%"; f.classList.toggle("full",pct===100);
}
function updateDone(){
  const done=state[week][session].done;
  const b=document.getElementById("doneBtn");
  b.classList.toggle("done",done);
  document.getElementById("doneTxt").textContent=done?"Séance terminée":"Marquer terminée";
}
function updateWeek(){ document.getElementById("weekNum").textContent=week; }

function renderAll(){ renderTabs(); updateWeek(); renderSession();
  document.getElementById("prevWeek").disabled=week===1;
  document.getElementById("nextWeek").disabled=week===WEEKS;
}

document.getElementById("infoBtn").onclick=function(){
  document.getElementById("help").classList.toggle("show");
  this.classList.toggle("on");
};
document.getElementById("prevWeek").onclick=()=>{if(week>1){week--; save(); renderAll();}};
document.getElementById("nextWeek").onclick=()=>{if(week<WEEKS){week++; save(); renderAll();}};
document.getElementById("notes").addEventListener("input",e=>{state[week][session].notes=e.target.value; save();});
document.getElementById("doneBtn").onclick=()=>{state[week][session].done=!state[week][session].done; updateDone(); renderTabs(); save();};
document.getElementById("resetBtn").onclick=()=>document.getElementById("modal").classList.add("show");
document.getElementById("mCancel").onclick=()=>document.getElementById("modal").classList.remove("show");
document.getElementById("modal").onclick=e=>{if(e.target.id==="modal")document.getElementById("modal").classList.remove("show");};
document.getElementById("mOk").onclick=()=>{state=emptyData(); week=1; session="A"; save(); document.getElementById("modal").classList.remove("show"); renderAll();};

let remaining=0, running=false, tick=null;
const tD=document.getElementById("timerD"), tIco=document.getElementById("timerIco"), tStop=document.getElementById("timerStop");
function fmt(s){return Math.floor(s/60)+":"+String(s%60).padStart(2,"0");}
function renderTimer(){
  tD.textContent=(running||remaining>0)?fmt(remaining):"Repos";
  tIco.classList.toggle("run",running);
  tD.classList.toggle("warn",running&&remaining<=10);
  tStop.classList.toggle("show",running||remaining>0);
}
function startTimer(sec){
  remaining=sec; running=true; renderTimer();
  clearInterval(tick);
  tick=setInterval(()=>{
    remaining--;
    if(remaining<=0){remaining=0; running=false; clearInterval(tick);
      if(navigator.vibrate) navigator.vibrate([200,100,200]);
    }
    renderTimer();
  },1000);
}
document.querySelectorAll(".t-btn").forEach(b=>b.onclick=()=>startTimer(+b.dataset.sec));
tStop.onclick=()=>{running=false; remaining=0; clearInterval(tick); renderTimer();};

renderAll();
</script>
</body>
</html>
